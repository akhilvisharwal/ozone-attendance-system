# Server
PORT=4000
NODE_ENV=development
# Frontend origin(s). Production: required. Comma-separate for preview URLs.
# Example production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Database (use Neon / Render Postgres in production — enable SSL automatically)
DATABASE_URL=postgresql://ozone:ozone_dev_password@localhost:5432/ozone_attendance
# DATABASE_SSL=true
# Optional PostgreSQL plan capacity for the Database settings panel (e.g. 1GB, 512MB).
# When unset, the panel defaults to 1 GB (or the admin-configured value in Settings → Database).
# Never uses local OS disk space.
# DATABASE_STORAGE_LIMIT=1GB

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin bootstrap (used by seed script)
ADMIN_EMPLOYEE_ID=OZNADMIN
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@ozoneaircon.com
ADMIN_PASSWORD=ChangeMe@123

# File storage
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=8

# Google Maps — one key powers server geocoding and browser maps (served via /api/settings/public)
GEOCODE_PROVIDER=google
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional local-only override for frontend dev without restarting backend
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Branding (optional overrides — defaults read from /branding/branding.json and assets/logo.png)
# COMPANY_NAME=Ozone Aircon
# COMPANY_LOGO_PATH=assets/logo.png

# Attendance rules
# Time of day after which a check-in counts as a "late arrival" on the admin dashboard
OFFICE_START_TIME=09:30:00

# Check-in / check-out timing rules (HH:MM, 24-hour clock, server timezone)
CHECKIN_OPEN_TIME=09:45        # before this time → classified as 'early'
CHECKIN_ONTIME_END=10:07       # on-time window; after this → 'late'
HALF_DAY_CUTOFF=11:30          # at or after this time → automatically half-day
CHECKOUT_STANDARD_TIME=18:30   # before this time → 'early' checkout; at/after → 'on_time'/'overtime'
# Set your local timezone so "today" boundaries line up with office hours
TZ=Asia/Kolkata
