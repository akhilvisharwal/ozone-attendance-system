# Server
PORT=4000
NODE_ENV=development
# Frontend origin(s). Production: required. Comma-separate for preview URLs.
# Example production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Database (use Neon / Render Postgres in production — enable SSL automatically)
DATABASE_URL=postgresql://ozone:ozone_dev_password@localhost:5432/ozone_attendance
# DATABASE_SSL=true
# Database storage capacity for the Settings → Database panel.
# Capacity is detected automatically in this order:
#   1. Render API (set RENDER_API_KEY below; the Postgres id is parsed from DATABASE_URL,
#      or set RENDER_POSTGRES_ID explicitly).
#   2. DATABASE_STORAGE_LIMIT below (explicit override, e.g. 1GB, 512MB, 10GB).
#   3. If neither is available, the panel shows the maximum as "Not available" and never
#      estimates a value. Current database size is always measured live from PostgreSQL.
# Never uses local OS disk space.
# DATABASE_STORAGE_LIMIT=1GB

# Optional: auto-detect the PostgreSQL plan's allocated disk size from Render.
# RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxxxxxx
# RENDER_POSTGRES_ID=dpg-xxxxxxxxxxxxxxxxxxxx

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin bootstrap (used by seed script)
ADMIN_EMPLOYEE_ID=OZNADMIN
ADMIN_NAME=System Administrator
ADMIN_EMAIL=info@ozoneairconhvac.com
ADMIN_PASSWORD=ChangeMe@123

# Email (Resend) — OTP verification, password reset, and admin notifications
# Never expose RESEND_API_KEY to the frontend.
RESEND_API_KEY=
EMAIL_FROM=noreply@app.ozoneairconhvac.com
# Inbox for ALL security OTP codes and password-reset links (required for OTP delivery).
# Do not reuse ADMIN_EMAIL here unless you intentionally want OTPs at the company inbox.
OTP_RECEIVER_EMAIL=security@ozoneairconhvac.com
# Optional override for operational (non-OTP) admin notification emails; defaults to ADMIN_EMAIL.
# NOTIFICATION_ADMIN_EMAIL=info@ozoneairconhvac.com
# Public app URL for password-reset links (defaults to CLIENT_URL)
APP_URL=http://localhost:5173

# Firebase Cloud Messaging (optional — push is skipped gracefully when unset)
# Prefer a single JSON string for the service account:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Or split fields:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Web client config (safe to expose to the browser):
# FIREBASE_WEB_API_KEY=
# FIREBASE_WEB_AUTH_DOMAIN=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_WEB_APP_ID=
# FIREBASE_VAPID_KEY=

# File storage
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=8

# Google Maps — server geocoding (Render) and optional browser key for /api/settings/public
GEOCODE_PROVIDER=google
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional dedicated browser key. When unset, GOOGLE_MAPS_API_KEY is served to the frontend.
# GOOGLE_MAPS_BROWSER_API_KEY=your_browser_restricted_maps_key_here

# Frontend (Vercel) — embed at build time; preferred for map previews in production.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Branding (optional overrides — defaults read from /branding/branding.json and assets/logo.png)
# COMPANY_NAME=Ozone Aircon
# COMPANY_LOGO_PATH=assets/logo.png

# Attendance rules
# Time of day after which a check-in counts as a "late arrival" on the admin dashboard
OFFICE_START_TIME=09:30:00

# Check-in / check-out timing rules (HH:MM, 24-hour clock, server timezone)
CHECKIN_OPEN_TIME=09:45        # before this time → classified as 'early'
CHECKIN_ONTIME_END=10:07       # on-time window; after this → 'late'
HALF_DAY_CUTOFF=11:30          # at or after this time → automatically half-day
CHECKOUT_STANDARD_TIME=18:30   # before this time → 'early' checkout; at/after → 'on_time'/'overtime'
# Set your local timezone so "today" boundaries line up with office hours
TZ=Asia/Kolkata
