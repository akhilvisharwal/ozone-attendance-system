{
  "name": "ozone-attendance-backend",
  "version": "1.0.0",
  "description": "Backend API for Ozone Aircon Attendance Management System",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "deploy:setup": "npm run migrate && npm run seed",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "reset-admin-password": "node scripts/reset-admin-password.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.12.12",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.6",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.10.5",
    "typescript": "~5.9.3"
  }
}
