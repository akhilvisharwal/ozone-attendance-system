# Frontend (Vite) — copy to frontend/.env.local for local development
#
# Production (Vercel): REQUIRED — Render API origin, no trailing slash.
# VITE_API_URL=https://ozone-attendance-api.onrender.com
#
# Local dev: leave unset so Vite proxies /api → localhost:4000
# VITE_API_URL=
# Optional — normally the backend serves the key via /api/settings/public.
# Set this only if you want maps to work before login or without the API.
VITE_GOOGLE_MAPS_API_KEY=
