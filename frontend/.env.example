# API origin — leave empty for local dev and production.
# Vite (dev) and Vercel (prod) proxy /api and /assets to the backend so auth cookies stay first-party.
# Required for mobile Safari / Chrome, which block third-party refresh cookies.
# Only set VITE_API_URL when you intentionally bypass the proxy (not recommended for production).
# VITE_API_URL=

# Google Maps JavaScript API key — optional locally (backend serves key via /api/settings/public).
# Required on Vercel for production map previews (embedded at build time).
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
