# Frontend (Vite) — copy to frontend/.env.local for local development
#
# Production (Vercel): REQUIRED — Render API origin, no trailing slash.
# VITE_API_URL=https://ozone-attendance-api.onrender.com
#
# Local dev: leave unset so Vite proxies /api → localhost:4000
# VITE_API_URL=

# Google Maps JavaScript API key (embedded at build time on Vercel).
# Use the same key as backend GOOGLE_MAPS_API_KEY with HTTP referrer restrictions.
# Local dev can omit this — the backend serves the key via /api/settings/public.
# VITE_GOOGLE_MAPS_API_KEY=
